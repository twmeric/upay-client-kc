## 3. 修復後端金額處理 (backend/server/src/index.ts)

```typescript
// backend/server/src/index.ts
// 修改 create order 函數

app.post("/api/public/payment/create", async (c) => {
  try {
    const { 
      amount, 
      payType, 
      subject, 
      body: orderBody, 
      returnUrl,
      idempotencyKey,
      channelExtra 
    } = await c.req.json();

    // 驗證金額
    const numAmount = parseFloat(amount);
    if (isNaN(numAmount) || numAmount <= 0) {
      return c.json({ error: "Invalid amount", code: "INVALID_AMOUNT" }, 400);
    }
    if (numAmount > 999999.99) {
      return c.json({ error: "Amount exceeds limit", code: "AMOUNT_TOO_LARGE" }, 400);
    }

    // 檢查冪等性
    if (idempotencyKey) {
      const existing = await edgespark.db
        .select()
        .from(tables.transactions)
        .where(eq(tables.transactions.idempotencyKey, idempotencyKey))
        .limit(1);
        
      if (existing.length > 0) {
        // 返回已存在的訂單
        const txn = existing[0];
        return c.json({
          success: true,
          orderNo: txn.orderNo,
          payUrl: txn.payUrl,
          payDataType: txn.payDataType,
          cached: true,
        });
      }
    }

    const config = getEasyLinkConfig(edgespark);
    const orderNo = generateOrderNo();
    
    // 金額轉換：元 -> 分
    const amountInCents = Math.round(numAmount * 100);

    // Determine worker URL for notify
    const requestUrl = new URL(c.req.url);
    const workerBaseUrl = `${requestUrl.protocol}//${requestUrl.host}`;
    const notifyUrl = `${workerBaseUrl}/api/webhooks/easylink/notify`;

    // Build EasyLink request params
    const wayCode = payType || "UP_OP";
    const finalSubject = subject || "Payment";
    const finalBody = orderBody || "Payment";
    const finalReturnUrl = returnUrl || `${requestUrl.protocol}//${requestUrl.host}/payment/result?orderNo=${orderNo}`;
    const reqTime = Date.now().toString();

    // 構建基本參數
    const signParams: Record<string, string> = {
      mchNo: config.mchNo,
      appId: config.appId,
      mchOrderNo: orderNo,
      wayCode,
      amount: amountInCents.toString(),
      currency: "HKD",
      subject: finalSubject,
      body: finalBody,
      notifyUrl,
      returnUrl: finalReturnUrl,
      reqTime,
      version: "1.0",
      signType: "MD5",
    };

    // 添加 channelExtra（如果有）
    if (channelExtra) {
      signParams.channelExtra = typeof channelExtra === 'string' 
        ? channelExtra 
        : JSON.stringify(channelExtra);
    }

    // 添加過期時間（30分鐘）
    signParams.expiredTime = "1800";

    // Generate sign
    const sign = await generateSign(signParams, config.appSecret);

    // Build request body
    const requestBody: Record<string, any> = {
      ...signParams,
      amount: amountInCents,  // int type
      reqTime: parseInt(reqTime, 10),  // long type
      sign,
    };

    console.log("[Payment] Creating order:", { 
      orderNo, 
      amount: amountInCents, 
      wayCode, 
      channelExtra: signParams.channelExtra,
      environment: config.environment 
    });

    // Call EasyLink API
    const response = await fetch(`${config.baseUrl}/api/pay/unifiedOrder`, {
      method: "POST",
      headers: { 
        "Content-Type": "application/json",
        "X-Request-ID": orderNo, // 用於追踪
      },
      body: JSON.stringify(requestBody),
    });

    const result = await response.json() as Record<string, any>;
    console.log("[Payment] EasyLink response:", JSON.stringify(result));

    // 檢查 API 返回
    if (!response.ok) {
      console.error("[Payment] HTTP error:", response.status);
      return c.json({ 
        success: false, 
        error: `Payment gateway error: ${response.status}`,
        code: "GATEWAY_ERROR"
      }, 502);
    }

    // Save transaction to DB
    await edgespark.db.insert(tables.transactions).values({
      orderNo,
      mchOrderNo: orderNo,
      mchNo: config.mchNo,
      amount: amountInCents,
      currency: "HKD",
      payType: wayCode,
      subject: finalSubject,
      body: finalBody,
      status: result.code === 0 ? 1 : 0,
      notifyUrl,
      returnUrl: finalReturnUrl,
      rawResponse: JSON.stringify(result),
      customerIp: c.req.header("cf-connecting-ip") || c.req.header("x-forwarded-for") || "",
      idempotencyKey: idempotencyKey || null,
      payUrl: result.data?.payData || null,
      payDataType: result.data?.payDataType || null,
      channelExtra: signParams.channelExtra || null,
    });

    if (result.code === 0) {
      const payData = result.data?.payData;
      const payDataType = result.data?.payDataType;
      
      console.log("[Payment] Success - payDataType:", payDataType, "payData:", payData?.substring(0, 100));
      
      return c.json({
        success: true,
        orderNo,
        payUrl: payData,
        payDataType,
        data: result.data,
      });
    } else {
      console.error("[Payment] EasyLink error:", result.code, result.msg);
      return c.json({
        success: false,
        orderNo,
        error: result.msg || "Payment creation failed",
        errorCode: result.code,
        data: result,
      }, 400);
    }
  } catch (error: any) {
    console.error("[Payment] Create order error:", error.message, error.stack);
    return c.json({ 
      error: "Internal server error",
      code: "INTERNAL_ERROR"
    }, 500);
  }
});
