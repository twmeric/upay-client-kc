## 4. 加強 Webhook 安全 (backend/server/src/index.ts)

```typescript
// backend/server/src/index.ts
// 替換 webhook handler

app.post("/api/webhooks/easylink/notify", async (c) => {
  const startTime = Date.now();
  
  try {
    // 1. 解析請求體
    let data: Record<string, any>;
    const contentType = c.req.header("content-type") || "";
    
    if (contentType.includes("application/x-www-form-urlencoded")) {
      const formData = await c.req.parseBody();
      data = formData as Record<string, any>;
    } else {
      data = await c.req.json() as Record<string, any>;
    }
    
    console.log("[Webhook] Received notification:", {
      mchOrderNo: data.mchOrderNo,
      state: data.state,
      timestamp: new Date().toISOString(),
    });

    // 2. 驗證必要字段
    if (!data.mchOrderNo || !data.sign || !data.state) {
      console.error("[Webhook] Missing required fields");
      return c.text("fail");
    }

    // 3. 獲取配置
    const config = getEasyLinkConfig(edgespark);

    // 4. 驗證時間戳（防止重放攻擊，5分鐘窗口）
    const reqTime = parseInt(data.reqTime || '0');
    const now = Date.now();
    if (Math.abs(now - reqTime) > 5 * 60 * 1000) {
      console.error("[Webhook] Request expired, reqTime:", reqTime, "now:", now);
      return c.text("fail");
    }

    // 5. 驗證商戶號匹配
    if (data.mchNo !== config.mchNo) {
      console.error("[Webhook] Mismatch mchNo:", data.mchNo, "expected:", config.mchNo);
      return c.text("fail");
    }

    // 6. 驗證簽名
    const receivedSign = data.sign;
    const params: Record<string, string> = {};
    for (const [k, v] of Object.entries(data)) {
      if (k !== "sign" && v !== undefined && v !== null && v !== "") {
        params[k] = String(v);
      }
    }
    const expectedSign = await generateSign(params, config.appSecret);

    if (receivedSign !== expectedSign) {
      console.error("[Webhook] Sign verification failed:", { 
        received: receivedSign, 
        expected: expectedSign,
        params: Object.keys(params)
      });
      return c.text("fail");
    }

    // 7. 查詢並驗證訂單存在
    const existingOrder = await edgespark.db
      .select()
      .from(tables.transactions)
      .where(eq(tables.transactions.orderNo, data.mchOrderNo))
      .limit(1);
      
    if (existingOrder.length === 0) {
      console.error("[Webhook] Order not found:", data.mchOrderNo);
      return c.text("fail");
    }

    const order = existingOrder[0];

    // 8. 驗證金額匹配（防止篡改）
    const notifyAmount = parseInt(data.amount || '0');
    if (notifyAmount !== order.amount) {
      console.error("[Webhook] Amount mismatch:", {
        notify: notifyAmount,
        order: order.amount
      });
      // 這是一個嚴重問題，但為了不影響用戶，仍然更新狀態並記錄
    }

    // 9. 更新訂單狀態
    const newStatus = parseInt(data.state || "0");
    const updateData: any = {
      status: newStatus,
      updatedAt: Math.floor(Date.now() / 1000),
      rawResponse: JSON.stringify(data),
      payType: data.wayCode || order.payType,
    };

    // 只有成功時才設置支付時間
    if (newStatus === 2 && order.status !== 2) {
      updateData.paidAt = Math.floor(Date.now() / 1000);
      updateData.channelOrderNo = data.channelOrderNo || null;
    }

    await edgespark.db
      .update(tables.transactions)
      .set(updateData)
      .where(eq(tables.transactions.orderNo, data.mchOrderNo));

    const duration = Date.now() - startTime;
    console.log("[Webhook] Updated order:", data.mchOrderNo, 
      "status:", newStatus, 
      "duration:", duration + "ms");

    return c.text("success");
    
  } catch (error: any) {
    console.error("[Webhook] Error:", error.message, error.stack);
    return c.text("fail");
  }
});
```

